# 環境変数の設定例
# このファイルをコピーして .env.local を作成し、実際の値を入力してください。

# --- 必須：Supabase（リード保存・テンプレート取得） ---
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- 必須：SendGrid（開発環境でメール送信する場合） ---
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=your-verified-sender-email@example.com

# --- 任意：管理者画面・CSVエクスポート用 ---
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- 任意：reCAPTCHA v3（未設定なら検証はスキップされます） ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-v3-secret-key

# --- 任意：Thanks 経由の診断ツール連携（16文字以上のランダム文字列。未設定なら ref は発行されません） ---
INSTAGRAM_REF_SECRET=your-16-char-or-longer-secret
